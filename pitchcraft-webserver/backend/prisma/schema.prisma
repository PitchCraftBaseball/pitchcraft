datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id            Int     @id
  first_name    String
  last_name     String
  birthdate     DateTime?
  team_id       Int?
  position      String
  batting_side  String
  throwing_arm  String
  height        Int?
  weight        Int?
  jersey_number Int?

  @@map("players")
}
