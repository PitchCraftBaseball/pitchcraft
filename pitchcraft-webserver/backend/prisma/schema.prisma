datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Player {
  id            Int     @id
  first_name    String
  last_name     String
  birthdate     DateTime?
  team_id       Int?
  position      String
  batting_side  String
  throwing_arm  String
  height        Int?
  weight        Int?
  jersey_number Int?
  active        Boolean?

  @@map("players")
}

model Schedule {
  game_id       BigInt   @id @default(autoincrement())
  game_datetime DateTime
  away_team     String   @db.VarChar(255)
  away_team_id  Int
  home_team     String   @db.VarChar(255)
  home_team_id  Int
  venue_id      Int
  venue_name    String   @db.VarChar(255)
  summary       String   @db.VarChar(255)

  @@map("schedule")
}