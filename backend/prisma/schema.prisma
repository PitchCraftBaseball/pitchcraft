// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model players {
  id             Int       @id
  first_name     String
  last_name      String
  birthdate      DateTime? @db.Date
  team_id        Int?
  position       String    @db.VarChar(3)
  batting_side   String    @db.Char(1)
  throwing_arm   String    @db.Char(1)
  height         Int?      @db.SmallInt
  weight         Int?      @db.SmallInt
  jersey_number  Int?      @db.SmallInt

  @@map("players")
}
